{
  "name": "boilerplate-apps-router",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "jest --passWithNoTests --maxWorkers=50%",
    "test:watch": "jest --watch --maxWorkers=25%",
    "codegen": "apollo codegen:generate --target typescript --excludes=node_modules/ --includes=src/graphql/**/*.ts --localSchemaFile schema.gql --tagName=gql --outputFlat src/graphql/generated",
    "schema:download": "apollo client:download-schema --endpoint=http://localhost:1337/graphql schema-temp.gql",
    "schema:convert": "node convertToNonNull.js",
    "types:generate": "npm run schema:download && npm run schema:convert && npm run codegen",
    "test:ci": "jest --runInBand",
    "generate": "plop --plopfile generators/plopfile.js",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@apollo/client": "^3.12.4",
    "@styled-icons/boxicons-regular": "^10.47.0",
    "@styled-icons/boxicons-solid": "^10.47.0",
    "@styled-icons/fa-brands": "^10.47.0",
    "@styled-icons/material-outlined": "^10.47.0",
    "@styled-icons/remix-fill": "^10.46.0",
    "dotenv": "^17.4.2",
    "graphql": "^15.5.1",
    "joi": "^18.1.2",
    "lodash.xor": "^4.5.0",
    "next": "14.2.16",
    "next-auth": "^4.24.14",
    "next-pwa": "^5.6.0",
    "nextjs-progressbar": "^0.0.16",
    "polished": "^4.3.1",
    "qs": "^6.13.1",
    "react": "^18",
    "react-dom": "^18",
    "react-slick": "^0.31.0",
    "styled-components": "^6.1.13",
    "styled-media-query": "^2.1.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash.xor": "^4.5.9",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.9.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-slick": "^0.23.13",
    "@types/styled-components": "^5.1.34",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "apollo": "^2.11.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-styled-components": "^2.1.4",
    "boilerplate-apps-router": "file:",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "husky": "^9.1.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fixed-jsdom": "^0.0.11",
    "jest-styled-components": "^7.2.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "plop": "^4.0.1",
    "prettier": "^3.8.1",
    "storybook": "^10.3.5",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "graphql": "^15.5.1"
  }
}
